# ── Deployment mode ───────────────────────────────────────────────────────────
# true  → cloud relay (Render) — no DB, MinIO, MQTT, UDP Discovery
# false → local full stack (default)
RELAY_MODE=false

# Public URL of this server — returned by /api/config for client auto-configuration.
# Set to https://atak-mi-server.onrender.com when deployed on Render.
# Leave blank for local; auto-detects ngrok if running.
SERVER_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── PostgreSQL (started via docker-compose) ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=atak_db

# ── MinIO (started via docker-compose) ────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=atakadmin
MINIO_SECRET_KEY=atakadmin123

# ── MQTT (disabled by default — set true only if you re-enable Mosquitto) ─────
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883

# ── Security (change this in production!) ─────────────────────────────────────
# This MUST be identical across local server and Render — both use it to sign/verify JWTs.
JWT_SECRET_KEY=tactical-secret-change-me
